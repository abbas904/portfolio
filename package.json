{
  "name": "abbas-portfolio",
  "version": "1.0.0",
  "description": "Modern responsive portfolio website for Abbas Rizk - Front-End Developer",
  "author": "Abbas Rizk",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:fast": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbo --port 3000",
    "dev:optimized": "npm run optimize && npm run dev:fast",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "export": "next export",
    "clean": "rm -rf .next out node_modules/.cache",
    "dev:clean": "npm run clean && npm run dev",
    "optimize": "node scripts/optimize.js"
  },
  "keywords": [
    "portfolio",
    "frontend",
    "developer",
    "react",
    "nextjs",
    "responsive",
    "modern"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abbas904/portfolio.git"
  },
  "homepage": "https://abbas904.github.io/portfolio",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.544.0",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-countup": "^6.5.3",
    "react-dom": "19.1.0",
    "react-icon": "^1.0.0",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "swiper": "^12.0.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  }
}
